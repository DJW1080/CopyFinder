<Window
    x:Class="CopyFinder.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:CopyFinder.ViewModels"
    Title="Technification CopyFinder">


    <Grid
        Padding="0"
        Background="{StaticResource AppBackgroundBrush}"
        RowSpacing="0">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Padding="0"
            Background="{StaticResource HeaderBackgroundBrush}"
            BorderBrush="{StaticResource PanelBorderBrush}"
            BorderThickness="0,0,0,1">
            <Grid>
                <Image
                    x:Name="AppLogoImage"
                    Width="800"
                    Height="85"
                    HorizontalAlignment="Center"
                    Source="ms-appx:///Technification/Logo/CopyFinder-Banner-08.png"
                    Stretch="Uniform" />
            </Grid>
        </Border>

        <Border
            Grid.Row="1"
            Margin="8,8,8,0"
            Padding="6"
            Background="{StaticResource PanelBackgroundBrush}"
            BorderBrush="{StaticResource PanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="4">

            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox
                    x:Name="FolderPathBox"
                    Background="{StaticResource SearchInputBackgroundBrush}"
                    BorderBrush="{StaticResource SearchInputBorderBrush}"
                    Foreground="{StaticResource SearchInputTextBrush}"
                    PlaceholderText="Choose or type a folder to scan" />
                <Button
                    x:Name="BrowseButton"
                    Grid.Column="1"
                    Click="BrowseButton_Click"
                    Content="Browse"
                    Style="{StaticResource TopButtonStyle}" />
                <Button
                    x:Name="ScanButton"
                    Grid.Column="2"
                    Click="ScanButton_Click"
                    Content="Scan"
                    Style="{StaticResource TopScanButtonStyle}" />
                <Button
                    x:Name="CancelButton"
                    Grid.Column="3"
                    Click="CancelButton_Click"
                    Content="Cancel"
                    IsEnabled="False"
                    Style="{StaticResource TopButtonStyle}" />
            </Grid>
        </Border>

        <Expander
            x:Name="SettingsPanel"
            Grid.Row="2"
            MinHeight="30"
            Margin="8,8,8,0"
            Padding="0"
            Background="{StaticResource PanelBackgroundBrush}"
            BorderBrush="{StaticResource PanelBorderBrush}"
            IsExpanded="False"
            RequestedTheme="Dark">
            <Expander.Header>
                <TextBlock
                    FontWeight="SemiBold"
                    Foreground="{StaticResource AppPrimaryBrush}"
                    Text="Scan Settings" />
            </Expander.Header>
            <Grid Padding="6,4,6,4" RowSpacing="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid ColumnSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Width="30"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource AppTextLightBrush}"
                        Text="Keep" />
                    <ComboBox
                        x:Name="KeepRuleComboBox"
                        Grid.Column="1"
                        Width="170"
                        HorizontalAlignment="Left"
                        Background="{StaticResource InputBackgroundBrush}"
                        BorderBrush="{StaticResource InputBorderBrush}"
                        Foreground="White"
                        Padding="14,8"
                        SelectedIndex="0"
                        SelectionChanged="KeepRuleComboBox_SelectionChanged">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Padding" Value="12,6" />
                            </Style>
                        </ComboBox.ItemContainerStyle>
                        <ComboBoxItem Content="Original" />
                        <ComboBoxItem Content="Shortest name" />
                        <ComboBoxItem Content="Oldest file" />
                        <ComboBoxItem Content="Newest file" />
                        <ComboBoxItem Content="Folder" />
                        <ComboBoxItem Content="Highest Resolution" />
                    </ComboBox>
                    <TextBlock
                        Grid.Column="2"
                        Width="40"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource AppTextLightBrush}"
                        Text="Folder" />
                    <TextBox
                        x:Name="PreferredFolderBox"
                        Grid.Column="3"
                        Width="400"
                        HorizontalAlignment="Left"
                        Background="{StaticResource InputBackgroundBrush}"
                        BorderBrush="{StaticResource InputBorderBrush}"
                        Foreground="White"
                        PlaceholderText="Used only by Prefer folder"
                        TextChanged="Setting_Changed" />
                    <TextBlock
                        Grid.Column="4"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource AppTextLightBrush}"
                        Text="Workers" />
                    <NumberBox
                        x:Name="HashWorkersBox"
                        Grid.Column="5"
                        Width="65"
                        Background="{StaticResource InputBackgroundBrush}"
                        BorderBrush="{StaticResource InputBorderBrush}"
                        Foreground="White"
                        LargeChange="2"
                        Maximum="16"
                        Minimum="1"
                        SmallChange="1"
                        ValueChanged="ScanLimitBox_ValueChanged" />
                </Grid>

                <Grid
                    Grid.Row="1"
                    ColumnSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Width="30"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource AppTextLightBrush}"
                        Text="Limit" />
                    <NumberBox
                        x:Name="ScanLimitBox"
                        Grid.Column="1"
                        Width="90"
                        Background="{StaticResource InputBackgroundBrush}"
                        BorderBrush="{StaticResource InputBorderBrush}"
                        Foreground="White"
                        LargeChange="500"
                        Maximum="10000"
                        Minimum="1"
                        SmallChange="50"
                        ValueChanged="ScanLimitBox_ValueChanged" />
                    <TextBlock
                        Grid.Column="2"
                        Width="50"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource AppTextLightBrush}"
                        Text="Min KB" />
                    <NumberBox
                        x:Name="MinimumSizeBox"
                        Grid.Column="3"
                        Width="70"
                        Background="{StaticResource InputBackgroundBrush}"
                        BorderBrush="{StaticResource InputBorderBrush}"
                        Foreground="White"
                        LargeChange="1024"
                        Minimum="0"
                        SmallChange="100"
                        ValueChanged="ScanLimitBox_ValueChanged" />
                    <TextBlock
                        Grid.Column="4"
                        Width="50"
                        VerticalAlignment="Center"
                        Foreground="{StaticResource AppTextLightBrush}"
                        Text="Exclude" />
                    <TextBox
                        x:Name="ExcludedExtensionsBox"
                        Grid.Column="5"
                        MinWidth="170"
                        HorizontalAlignment="Stretch"
                        Background="{StaticResource InputBackgroundBrush}"
                        BorderBrush="{StaticResource InputBorderBrush}"
                        Foreground="White"
                        PlaceholderText="tmp, bak, log"
                        TextChanged="Setting_Changed" />
                    <CheckBox
                        x:Name="SkipHiddenCheckBox"
                        Grid.Column="6"
                        Checked="Setting_Changed"
                        Content="Skip hidden files"
                        Foreground="{StaticResource AppTextLightBrush}"
                        Unchecked="Setting_Changed" />
                    <CheckBox
                        x:Name="SkipSystemCheckBox"
                        Grid.Column="7"
                        Checked="Setting_Changed"
                        Content="Skip system files"
                        Foreground="{StaticResource AppTextLightBrush}"
                        Unchecked="Setting_Changed" />
                </Grid>
            </Grid>
        </Expander>

        <!--  Progress Panel  -->
        <Border
            Grid.Row="3"
            Margin="8,8,8,0"
            Padding="8"
            Background="{StaticResource PanelBackgroundBrush}"
            BorderBrush="{StaticResource PanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="4">

            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ProgressBar
                    x:Name="ScanProgressBar"
                    IsIndeterminate="False"
                    Maximum="100"
                    Minimum="0"
                    Height="8"
                    Margin="0,4,0,4" />

                <TextBlock
                    x:Name="SummaryText"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    FontWeight="Medium"
                    Foreground="{StaticResource AppTextSecondaryBrush}"
                    Text="No scan run yet." />
            </Grid>
        </Border>

        <Border
            Grid.Row="4"
            Margin="8,8,8,0"
            Background="{StaticResource AppSurfaceBrush}"
            BorderBrush="{StaticResource AppBorderBrush}"
            BorderThickness="1"
            CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border
                    Background="{StaticResource TableHeaderBrush}"
                    BorderBrush="{StaticResource TableHeaderBorderBrush}"
                    BorderThickness="0,0,0,1">
                    <Grid
                        Padding="8,6"
                        HorizontalAlignment="Stretch"
                        ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36" />
                            <ColumnDefinition Width="64" />
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="70" />
                            <ColumnDefinition Width="118" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="2"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TableHeaderTextBrush}"
                            Text="Actions" />
                        <TextBlock
                            Grid.Column="3"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TableHeaderTextBrush}"
                            Text="File Name" />
                        <TextBlock
                            Grid.Column="4"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TableHeaderTextBrush}"
                            Text="Size" />
                        <TextBlock
                            Grid.Column="5"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TableHeaderTextBrush}"
                            Text="Modified" />
                        <TextBlock
                            Grid.Column="6"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource TableHeaderTextBrush}"
                            Text="Path" />
                    </Grid>
                </Border>

                <ListView
                    x:Name="DuplicateGroupList"
                    Grid.Row="1"
                    Padding="0"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    Background="Transparent"
                    BorderThickness="0"
                    IsItemClickEnabled="False"
                    ItemsSource="{x:Bind DuplicateGroups, Mode=OneWay}"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    SelectionMode="None">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="MinHeight" Value="0" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:DuplicateGroupViewModel">
                            <Expander
                                Margin="0"
                                Padding="0"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                IsExpanded="True"
                                RequestedTheme="Dark">
                                <Expander.Header>
                                    <Border
                                        Background="{StaticResource GroupHeaderBrush}"
                                        BorderBrush="{StaticResource GroupHeaderBorderBrush}"
                                        BorderThickness="0,0,0,1">
                                        <Grid
                                            Padding="8,4"
                                            HorizontalAlignment="Stretch"
                                            ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="92" />
                                                <ColumnDefinition Width="154" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                FontWeight="SemiBold"
                                                Foreground="{StaticResource GroupHeaderTextBrush}"
                                                Text="{x:Bind HeaderText, Mode=OneWay}" />
                                            <StackPanel
                                                Grid.Column="1"
                                                Orientation="Horizontal"
                                                Spacing="6">
                                                <Button
                                                    Click="SelectGroupButton_Click"
                                                    Content="Select"
                                                    Style="{StaticResource ReviewButtonStyle}"
                                                    Tag="{x:Bind GroupId}" />
                                                <Button
                                                    Click="DeselectGroupButton_Click"
                                                    Content="Deselect"
                                                    Style="{StaticResource ReviewButtonStyle}"
                                                    Tag="{x:Bind GroupId}" />
                                            </StackPanel>
                                            <TextBlock
                                                Grid.Column="2"
                                                Foreground="{StaticResource GroupHeaderTextBrush}"
                                                Text="{x:Bind ConfidenceText}" />
                                        </Grid>
                                    </Border>
                                </Expander.Header>

                                <StackPanel HorizontalAlignment="Stretch" Spacing="0">
                                    <ItemsControl HorizontalAlignment="Stretch" ItemsSource="{x:Bind Files}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel HorizontalAlignment="Stretch" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemContainerStyle>
                                            <Style TargetType="ContentPresenter">
                                                <Setter Property="HorizontalAlignment" Value="Stretch" />
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            </Style>
                                        </ItemsControl.ItemContainerStyle>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:DuplicateFileViewModel">
                                                <Grid
                                                    Padding="8,6"
                                                    HorizontalAlignment="Stretch"
                                                    Background="{x:Bind RowBackground, Mode=OneWay}"
                                                    ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="36" />
                                                        <ColumnDefinition Width="64" />
                                                        <ColumnDefinition Width="130" />
                                                        <ColumnDefinition Width="220" />
                                                        <ColumnDefinition Width="70" />
                                                        <ColumnDefinition Width="118" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <CheckBox
                                                        Width="24"
                                                        MinWidth="0"
                                                        Padding="0"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center"
                                                        IsChecked="{x:Bind IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        IsEnabled="{x:Bind IsDuplicate, Mode=OneWay}" />
                                                    <Border
                                                        Grid.Column="1"
                                                        Width="52"
                                                        Height="52"
                                                        HorizontalAlignment="Left"
                                                        Background="{StaticResource GroupHeaderBrush}"
                                                        BorderBrush="{StaticResource AppBorderBrush}"
                                                        BorderThickness="1">
                                                        <Image
                                                            Width="50"
                                                            Height="50"
                                                            Source="{x:Bind ThumbnailSource}"
                                                            Stretch="Uniform" />
                                                    </Border>

                                                    <StackPanel
                                                        Grid.Column="2"
                                                        VerticalAlignment="Center"
                                                        Orientation="Horizontal"
                                                        Spacing="4">
                                                        <Button
                                                            Click="KeepFileButton_Click"
                                                            Content="Keep"
                                                            IsEnabled="{x:Bind IsDuplicate, Mode=OneWay}"
                                                            Style="{StaticResource SmallReviewButtonStyle}"
                                                            Tag="{x:Bind Path}" />
                                                        <Button
                                                            Click="OpenFileButton_Click"
                                                            Content="Open"
                                                            Style="{StaticResource SmallReviewButtonStyle}"
                                                            Tag="{x:Bind Path}" />
                                                    </StackPanel>

                                                    <TextBlock
                                                        Grid.Column="3"
                                                        VerticalAlignment="Center"
                                                        Foreground="{x:Bind RowTextBrush, Mode=OneWay}"
                                                        Text="{x:Bind FileName}"
                                                        TextTrimming="CharacterEllipsis" />
                                                    <TextBlock
                                                        Grid.Column="4"
                                                        VerticalAlignment="Center"
                                                        Foreground="{x:Bind RowTextBrush, Mode=OneWay}"
                                                        Text="{x:Bind SizeText}" />
                                                    <TextBlock
                                                        Grid.Column="5"
                                                        VerticalAlignment="Center"
                                                        Foreground="{x:Bind RowTextBrush, Mode=OneWay}"
                                                        Text="{x:Bind LastWriteText}" />
                                                    <TextBlock
                                                        Grid.Column="6"
                                                        VerticalAlignment="Center"
                                                        Foreground="{x:Bind RowTextBrush, Mode=OneWay}"
                                                        Text="{x:Bind Path}"
                                                        TextTrimming="CharacterEllipsis" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Expander>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <Border
            Grid.Row="5"
            Margin="8,8,8,8"
            Padding="8"
            Background="{StaticResource PanelBackgroundBrush}"
            BorderBrush="{StaticResource PanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="4">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    x:Name="StatusText"
                    VerticalAlignment="Center"
                    FontWeight="Medium"
                    Foreground="{StaticResource AppTextSecondaryBrush}" />
                <Button
                    x:Name="ExportButton"
                    Grid.Column="1"
                    Click="ExportButton_Click"
                    Content="Export report"
                    IsEnabled="False"
                    Style="{StaticResource BlueButtonStyle}" />
                <Button
                    x:Name="SelectAllDuplicatesButton"
                    Grid.Column="2"
                    Click="SelectAllDuplicatesButton_Click"
                    Content="Select duplicates"
                    IsEnabled="False"
                    Style="{StaticResource BlueButtonStyle}" />
                <Button
                    x:Name="DeselectAllButton"
                    Grid.Column="3"
                    Click="DeselectAllButton_Click"
                    Content="Deselect all"
                    IsEnabled="False"
                    Style="{StaticResource BlueButtonStyle}" />
                <Button
                    x:Name="DeleteButton"
                    Grid.Column="4"
                    Click="DeleteButton_Click"
                    Content="Delete Duplicates"
                    IsEnabled="False"
                    Style="{StaticResource StrongBlueButtonStyle}" />
            </Grid>
        </Border>
    </Grid>
</Window>
